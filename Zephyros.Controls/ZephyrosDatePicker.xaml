<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Zephyros.Controls.ZephyrosDatePicker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Zephyros.Controls"
    mc:Ignorable="d"
    MinHeight="32">

    <UserControl.Resources>
        <Style x:Key="PickerBottomActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Button x:Name="PickerButton"
                Height="32"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalAlignment="Stretch"
                Click="PickerButton_Click"
                Padding="0"
                Margin="0"
                BorderThickness="0"
                Background="Transparent"
                KeyDown="PickerButton_KeyDown">

            <Border x:Name="OuterBorder"
                    Height="32"
                    Background="{ThemeResource CardBg}"
                    BorderBrush="{ThemeResource DatePickerBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="0">

                <Grid Padding="12,0,12,0"
                      ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="DisplayTextBlock"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="month / day / year"
                               Foreground="{ThemeResource DatePickerPlaceholderBrush}"
                               FontSize="14"
                               TextTrimming="CharacterEllipsis"/>

                    <FontIcon x:Name="CalendarIcon"
                              Grid.Column="1"
                              Glyph="&#xE787;"
                              FontFamily="Segoe Fluent Icons"
                              FontSize="12"
                              VerticalAlignment="Center"
                              Foreground="{ThemeResource DatePickerIconBrush}"
                              Tapped="CalendarIcon_Tapped"/>
                </Grid>
            </Border>

            <Button.Flyout>
                <Flyout x:Name="PickerFlyout"
                        Placement="BottomEdgeAlignedLeft"
                        Opened="PickerFlyout_Opened"
                        Closed="PickerFlyout_Closed">
                    <Flyout.FlyoutPresenterStyle>
                        <Style TargetType="FlyoutPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="CornerRadius" Value="0"/>
                        </Style>
                    </Flyout.FlyoutPresenterStyle>

                    <Border x:Name="FlyoutRoot"
                            Background="{ThemeResource DatePickerFlyoutBackgroundBrush}"
                            BorderBrush="{ThemeResource DatePickerFlyoutBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="0"
                            Width="410"
                            Opacity="0"
                            RenderTransformOrigin="0.5,0">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="FlyoutScaleTransform"
                                                ScaleX="0.985"
                                                ScaleY="0.985"/>
                                <TranslateTransform x:Name="FlyoutTranslateTransform"
                                                    X="0"
                                                    Y="-6"/>
                            </TransformGroup>
                        </Border.RenderTransform>

                        <Grid x:Name="FlyoutContentRoot"
                              KeyDown="FlyoutRoot_KeyDown"
                              IsTabStop="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="342"/>
                                <RowDefinition Height="42"/>
                            </Grid.RowDefinitions>

                            <!-- PICKER AREA -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="PartColumn1" Width="2*"/>
                                    <ColumnDefinition x:Name="DividerColumn1" Width="1"/>
                                    <ColumnDefinition x:Name="PartColumn2" Width="1.05*"/>
                                    <ColumnDefinition x:Name="DividerColumn2" Width="1"/>
                                    <ColumnDefinition x:Name="PartColumn3" Width="1.15*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.ColumnSpan="5"
                                        Height="38"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource DatePickerSelectionBackgroundBrush}"
                                        BorderBrush="{ThemeResource DatePickerSelectionBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        IsHitTestVisible="False"/>

                                <controls:ZephyrosWheelColumn x:Name="MonthWheel"
                                                              Grid.Column="0"
                                                              Height="342"
                                                              IsCircular="True"
                                                              ItemTextAlignment="Left"/>

                                <Border x:Name="Separator1"
                                        Grid.Column="1"
                                        Width="1"
                                        Background="{ThemeResource DatePickerSeparatorBrush}"
                                        Opacity="0.9"/>

                                <controls:ZephyrosWheelColumn x:Name="DayWheel"
                                                              Grid.Column="2"
                                                              Height="342"
                                                              IsCircular="True"
                                                              ItemTextAlignment="Center"/>

                                <Border x:Name="Separator2"
                                        Grid.Column="3"
                                        Width="1"
                                        Background="{ThemeResource DatePickerSeparatorBrush}"
                                        Opacity="0.9"/>

                                <controls:ZephyrosWheelColumn x:Name="YearWheel"
                                                              Grid.Column="4"
                                                              Height="342"
                                                              IsCircular="False"
                                                              ItemTextAlignment="Left"/>
                            </Grid>

                            <!-- BOTTOM BAR -->
                            <Grid Grid.Row="1"
                                  Height="42"
                                  BorderBrush="{ThemeResource DatePickerFlyoutBorderBrush}"
                                  BorderThickness="0,1,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Style="{StaticResource PickerBottomActionButtonStyle}"
                                        Content="✔"
                                        FontSize="16"
                                        Foreground="{ThemeResource DatePickerTextBrush}"
                                        Click="AcceptButton_Click"/>

                                <Border Grid.Column="1"
                                        Width="1"
                                        Background="{ThemeResource DatePickerFlyoutBorderBrush}"/>

                                <Button Grid.Column="2"
                                        Style="{StaticResource PickerBottomActionButtonStyle}"
                                        Content="✕"
                                        FontSize="16"
                                        Foreground="{ThemeResource DatePickerTextBrush}"
                                        Click="CancelButton_Click"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Flyout>
            </Button.Flyout>
        </Button>
    </Grid>
</UserControl>